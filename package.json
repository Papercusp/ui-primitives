{
  "name": "@papercusp/ui-primitives",
  "version": "0.0.1",
  "private": true,
  "description": "Shared headless React UI primitives — ANSI/terminal output, markdown (GFM), JSON tree viewer, and virtualized lists — used across Papercusp surfaces. Brand-value-free; styling is injected by consumers.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./override": {
      "types": "./src/override/index.ts",
      "import": "./src/override/index.ts",
      "default": "./src/override/index.ts"
    }
  },
  "peerDependencies": {
    "anser": "*",
    "lucide-react": "*",
    "react": "^18 || ^19",
    "react-json-view-lite": "*",
    "react-markdown": "*",
    "react-virtuoso": "*",
    "remark-gfm": "*"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "lostpixel": "lost-pixel",
    "lostpixel:update": "LOST_PIXEL_GENERATE_ONLY=1 lost-pixel"
  },
  "devDependencies": {
    "@papercusp/test-config": "*",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.1.1",
    "lost-pixel": "^3.22.0",
    "storybook": "^10.3.6",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  }
}
